# Server
# Note: on macOS port 5000 is used by AirPlay Receiver — use 5001 locally if so.
PORT=5001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/pestrack

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY=24h

# Default admin (used by seed script)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@sotaico.com
ADMIN_PASSWORD=Admin@123

# File storage (AWS S3 or equivalent)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=eu-west-1
AWS_BUCKET_NAME=pestrack-photos

# Frontend URL
FRONTEND_URL=https://pestrack.gouna.sotaico.com
